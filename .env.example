DATABASE_URL=sqlite:///books.db
#DATABASE_URL=postgresql://admin:password@booklogr-db/booklogr
AUTH_SECRET_KEY=
AUTH_ALLOW_REGISTRATION=True
AUTH_REQUIRE_VERIFICATION=False
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
EXPORT_FOLDER="export_data"
SINGLE_USER_MODE=False

# UNCOMMENT TO ADD A USER AT STARTUP, REQUIRED FOR DEMO MODE
#AUTH_DEFAULT_USER=demo@booklogr.app
#AUTH_DEFAULT_PASSWORD=demo

# MAIL SETTINGS
MAIL_SERVER=smtp.example.com
MAIL_USERNAME=username
MAIL_PASSWORD=password
MAIL_SENDER=noreply@example.com

# docker-compose
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=booklogr

OIDC_CLIENT_ID=myclient
OIDC_CLIENT_SECRET=xxx
OIDC_REDIRECT_URI=http://{frontend-ip-or-domain}/callback
OIDC_DISCOVERY_URL=http://{oidc-server-ip-or-domain}/.well-known/openid-configuration